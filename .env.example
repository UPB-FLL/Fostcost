# ── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-random-secret-string
PORT=5000

# ── Square ───────────────────────────────────────────────────────────────────
# Get from: https://developer.squareup.com/apps  →  OAuth  →  Access Token
SQUARE_ACCESS_TOKEN=your-square-access-token-here

# ── SpotOn ───────────────────────────────────────────────────────────────────
# Get from your SpotOn developer portal / account manager
SPOTON_API_KEY=your-spoton-api-key-here
SPOTON_BASE_URL=https://api.spoton.com/v1
